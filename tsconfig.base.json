{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@wc-chatter/shared": ["packages/shared/src/index.ts"],
      "@wc-chatter/shared/mock-data": ["packages/shared/src/mock-data.ts"]
    }
  }
}
