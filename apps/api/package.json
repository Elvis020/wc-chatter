{
  "name": "@wc-chatter/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "build": "wrangler deploy --dry-run --env production --outdir dist",
    "deploy": "wrangler deploy --env production",
    "sync:rooms": "bun src/scripts/sync-rooms.ts",
    "types": "wrangler types src/worker-configuration.d.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@wc-chatter/shared": "workspace:*",
    "hono": "^4.9.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260617.1",
    "bun-types": "^1.3.13",
    "typescript": "^5.8.3",
    "wrangler": "^4.101.0"
  }
}
