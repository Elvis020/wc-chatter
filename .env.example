# Backend
PORT=8787
APP_ORIGIN=http://localhost:5173
API_PUBLIC_URL=http://localhost:8787

# Supabase
# Keep the service role key on the backend only. Never expose it to Vite/client code.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me

# Frontend
VITE_API_URL=http://localhost:8787
VITE_WS_URL=ws://localhost:8787/ws
# Set to false in production to hide the visible username reset control.
VITE_ENABLE_USERNAME_RESET=true
