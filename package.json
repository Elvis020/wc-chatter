{
  "name": "wc-chatter",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,yellow \"bun --filter @wc-chatter/web dev\" \"bun --filter @wc-chatter/api dev\"",
    "build": "bun run build:shared && bun run build:api && bun run build:web",
    "build:shared": "bun --filter @wc-chatter/shared build",
    "build:web": "bun --filter @wc-chatter/web build",
    "build:api": "bun --filter @wc-chatter/api build",
    "typecheck": "bun run typecheck:shared && bun run typecheck:api && bun run typecheck:web",
    "typecheck:shared": "bun --filter @wc-chatter/shared typecheck",
    "typecheck:web": "bun --filter @wc-chatter/web typecheck",
    "typecheck:api": "bun --filter @wc-chatter/api typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.9.2"
  }
}
